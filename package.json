{
  "name": "tokenrace",
  "version": "0.1.19",
  "description": "Monitor en tiempo real para Claude Code",
  "bin": {
    "tokenrace": "bin/cli.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/cli.js",
    "dev:server": "node bin/cli.js",
    "dev:web": "cd web && npm run dev",
    "build": "cd web && npm install && npm run build",
    "test": "node --test test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^4.18.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "supertest": "^7.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "telemetry",
    "dashboard",
    "opentelemetry",
    "otlp",
    "tokens",
    "cost"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franciscovaleromartin/tokenrace.git"
  },
  "homepage": "https://github.com/franciscovaleromartin/tokenrace#readme",
  "bugs": {
    "url": "https://github.com/franciscovaleromartin/tokenrace/issues"
  }
}
